# Optional text-message notifications via SMTP email-to-SMS gateway.
# Copy to .env.smtp and fill in real values. Do not commit .env.smtp.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASSWORD=your-google-app-password
TEXT_EMAIL_FROM=your-gmail-address@gmail.com
# Use your carrier's email-to-SMS/MMS gateway address, e.g. 15551234567@vtext.com.
TEXT_EMAIL_TO=phone-number@gateway.example
